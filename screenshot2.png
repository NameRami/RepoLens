<!DOCTYPE html>
<!-- saved from url=(0014)about:internet -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Repo Intel Dashboard Pro</title>
  <link rel="stylesheet" href="./screenshot2_files/styles.css">
</head>
<body>
  <div class="background-orb orb-one"></div>
  <div class="background-orb orb-two"></div>

  <main class="app-shell">
    <header class="hero">
      <nav class="nav">
        <div class="brand">
          <div class="brand-mark">RI</div>
          <div>
            <p class="eyebrow">GitHub analytics</p>
            <h1>Repo Intel Dashboard</h1>
          </div>
        </div>
        <a class="github-link" href="https://github.com/" target="_blank" rel="noreferrer">Open GitHub</a>
      </nav>

      <section class="hero-grid">
        <div>
          <p class="pill">Local-first developer intelligence</p>
          <h2>Turn any GitHub profile into a ranked portfolio report.</h2>
          <p class="hero-copy">
            Analyze repositories, score project strength, inspect language mix, and identify portfolio-ready work from a polished local dashboard.
          </p>

          <form id="searchForm" class="search-panel">
            <div class="input-wrap">
              <span>@</span>
              <input id="usernameInput" type="text" placeholder="GitHub username" autocomplete="off">
            </div>
            <button type="submit">Analyze profile</button>
          </form>

          <p class="hint">Try <button class="ghost-button" data-user="namerami">namerami</button> or <button class="ghost-button" data-user="torvalds">torvalds</button></p>
        </div>

        <div class="signal-card">
          <p class="signal-label">Portfolio signal</p>
          <div class="signal-score" id="signalScore">30</div>
          <p id="signalText">Moderate signal. Good activity, but README polish and positioning may help.</p>
        </div>
      </section>
    </header>

    <section id="status" class="status error">Failed to fetch</section>

    <section class="metric-grid">
      <article class="metric-card">
        <span>Total repos</span>
        <strong id="totalRepos">9</strong>
      </article>
      <article class="metric-card">
        <span>Total stars</span>
        <strong id="totalStars">0</strong>
      </article>
      <article class="metric-card">
        <span>Total forks</span>
        <strong id="totalForks">0</strong>
      </article>
      <article class="metric-card">
        <span>Recent repos</span>
        <strong id="recentRepos">9</strong>
      </article>
    </section>

    <section class="dashboard-grid">
      <article class="panel chart-panel">
        <div class="panel-header">
          <div>
            <p class="eyebrow">Distribution</p>
            <h3>Language mix</h3>
          </div>
          <span id="languageCount" class="chip">5 languages</span>
        </div>
        <div id="languageChart" class="bar-stack">
        <div class="bar-row">
          <div class="bar-label" title="Python">Python</div>
          <div class="track"><div class="fill" style="width:100%"></div></div>
          <div class="bar-value">4</div>
        </div>
      
        <div class="bar-row">
          <div class="bar-label" title="HTML">HTML</div>
          <div class="track"><div class="fill" style="width:50%"></div></div>
          <div class="bar-value">2</div>
        </div>
      
        <div class="bar-row">
          <div class="bar-label" title="Java">Java</div>
          <div class="track"><div class="fill" style="width:25%"></div></div>
          <div class="bar-value">1</div>
        </div>
      
        <div class="bar-row">
          <div class="bar-label" title="Unknown">Unknown</div>
          <div class="track"><div class="fill" style="width:25%"></div></div>
          <div class="bar-value">1</div>
        </div>
      
        <div class="bar-row">
          <div class="bar-label" title="HCL">HCL</div>
          <div class="track"><div class="fill" style="width:25%"></div></div>
          <div class="bar-value">1</div>
        </div>
      </div>
      </article>

      <article class="panel chart-panel">
        <div class="panel-header">
          <div>
            <p class="eyebrow">Ranking</p>
            <h3>Top projects by score</h3>
          </div>
          <span class="chip">weighted</span>
        </div>
        <div id="scoreChart" class="score-bars">
        <div class="score-row">
          <div class="score-label" title="LiveTVTower">LiveTVTower</div>
          <div class="track"><div class="fill" style="width:100%"></div></div>
          <div class="score-value">35</div>
        </div>
      
        <div class="score-row">
          <div class="score-label" title="QuickShare">QuickShare</div>
          <div class="track"><div class="fill" style="width:100%"></div></div>
          <div class="score-value">35</div>
        </div>
      
        <div class="score-row">
          <div class="score-label" title="ClipSync">ClipSync</div>
          <div class="track"><div class="fill" style="width:100%"></div></div>
          <div class="score-value">35</div>
        </div>
      
        <div class="score-row">
          <div class="score-label" title="SlideRemote">SlideRemote</div>
          <div class="track"><div class="fill" style="width:100%"></div></div>
          <div class="score-value">35</div>
        </div>
      
        <div class="score-row">
          <div class="score-label" title="PressRadar">PressRadar</div>
          <div class="track"><div class="fill" style="width:100%"></div></div>
          <div class="score-value">35</div>
        </div>
      
        <div class="score-row">
          <div class="score-label" title="LiveTVTower-Android">LiveTVTower-Android</div>
          <div class="track"><div class="fill" style="width:89%"></div></div>
          <div class="score-value">31</div>
        </div>
      
        <div class="score-row">
          <div class="score-label" title="code2prompt">code2prompt</div>
          <div class="track"><div class="fill" style="width:66%"></div></div>
          <div class="score-value">23</div>
        </div>
      
        <div class="score-row">
          <div class="score-label" title="cloud-automation-lab">cloud-automation-lab</div>
          <div class="track"><div class="fill" style="width:54%"></div></div>
          <div class="score-value">19</div>
        </div>
      </div>
      </article>
    </section>

    <section class="panel controls-panel">
      <div>
        <p class="eyebrow">Repository explorer</p>
        <h3>Ranked repositories</h3>
      </div>

      <div class="controls">
        <select id="languageFilter"><option value="all">All languages</option><option value="Python">Python</option><option value="HTML">HTML</option><option value="Java">Java</option><option value="Unknown">Unknown</option><option value="HCL">HCL</option></select>
        <select id="sortSelect">
          <option value="score">Sort by score</option>
          <option value="stars">Sort by stars</option>
          <option value="forks">Sort by forks</option>
          <option value="updated">Sort by updated</option>
          <option value="name">Sort by name</option>
        </select>
      </div>
    </section>

    <section id="repoGrid" class="repo-grid">
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/LiveTVTower" target="_blank" rel="noreferrer">LiveTVTower</a></h4>
            <div class="score-badge">35</div>
          </div>

          <p class="repo-desc">Watch 800+ live TV channels in a 1×1 to 3×3 multi-stream wall. One HTML file, no install, no subscription.</p>

          <div class="repo-meta">
            <span>HTML</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            <span>MIT</span>
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Jun 15, 2026</span>
            <span>1.6K KB</span>
          </div>
        </article>
      
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/QuickShare" target="_blank" rel="noreferrer">QuickShare</a></h4>
            <div class="score-badge">35</div>
          </div>

          <p class="repo-desc">Fast local Wi-Fi file sharing from any browser drag, drop, scan, download. No cloud, no USB, no app install.</p>

          <div class="repo-meta">
            <span>Python</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            <span>MIT</span>
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Jun 15, 2026</span>
            <span>308 KB</span>
          </div>
        </article>
      
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/ClipSync" target="_blank" rel="noreferrer">ClipSync</a></h4>
            <div class="score-badge">35</div>
          </div>

          <p class="repo-desc">Lightweight wireless clipboard sync and shared notepad for devices on the same Wi-Fi, no app, no cloud, just open a browser.</p>

          <div class="repo-meta">
            <span>Python</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            <span>MIT</span>
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Jun 15, 2026</span>
            <span>96 KB</span>
          </div>
        </article>
      
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/SlideRemote" target="_blank" rel="noreferrer">SlideRemote</a></h4>
            <div class="score-badge">35</div>
          </div>

          <p class="repo-desc">Wireless presentation remote, run a Python script on Windows, open the URL on any browser on any device, tap left/right to control your slides over Wi-Fi.</p>

          <div class="repo-meta">
            <span>Python</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            <span>MIT</span>
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Jun 15, 2026</span>
            <span>54 KB</span>
          </div>
        </article>
      
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/PressRadar" target="_blank" rel="noreferrer">PressRadar</a></h4>
            <div class="score-badge">35</div>
          </div>

          <p class="repo-desc">Real-time global news and event monitoring dashboard with live headlines, earthquake and NASA alerts, a 3D globe, topic and region filters, and a live TV wall.</p>

          <div class="repo-meta">
            <span>HTML</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            <span>MIT</span>
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Jun 15, 2026</span>
            <span>1.9K KB</span>
          </div>
        </article>
      
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/LiveTVTower-Android" target="_blank" rel="noreferrer">LiveTVTower-Android</a></h4>
            <div class="score-badge">31</div>
          </div>

          <p class="repo-desc">Java Android live TV app with 800+ channels, searchable TV browser, fullscreen playback, and automatic stream fallback.</p>

          <div class="repo-meta">
            <span>Java</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            <span>MIT</span>
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Jun 17, 2026</span>
            <span>31 KB</span>
          </div>
        </article>
      
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/code2prompt" target="_blank" rel="noreferrer">code2prompt</a></h4>
            <div class="score-badge">23</div>
          </div>

          <p class="repo-desc">Turn any codebase into clean, prompt-ready context in seconds.</p>

          <div class="repo-meta">
            <span>Python</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            <span>MIT</span>
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Apr 23, 2026</span>
            <span>3 KB</span>
          </div>
        </article>
      
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/cloud-automation-lab" target="_blank" rel="noreferrer">cloud-automation-lab</a></h4>
            <div class="score-badge">19</div>
          </div>

          <p class="repo-desc">No description yet. Add a strong README-style summary to improve portfolio clarity.</p>

          <div class="repo-meta">
            <span>Unknown</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Jun 14, 2026</span>
            <span>13 KB</span>
          </div>
        </article>
      
        <article class="repo-card">
          <div class="repo-top">
            <h4><a href="https://github.com/NameRami/terraform-ansible-project" target="_blank" rel="noreferrer">terraform-ansible-project</a></h4>
            <div class="score-badge">19</div>
          </div>

          <p class="repo-desc">I manually built a Terraform project to provision Azure infrastructure, starting from resource groups and expanding to networking and virtual machines, learning infrastructure-as-code step by step.</p>

          <div class="repo-meta">
            <span>HCL</span>
            <span>★ 0</span>
            <span>⑂ 0</span>
            
            
            
          </div>

          <div class="repo-footer">
            <span>Updated Apr 22, 2026</span>
            <span>2 KB</span>
          </div>
        </article>
      </section>
  </main>

  <script src="./screenshot2_files/app.js.download"></script>


</body></html>